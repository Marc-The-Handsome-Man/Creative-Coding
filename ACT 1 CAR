function setup() {
  createCanvas(400, 400);
}

function draw() {
  background(255); //background 
  
  // Car body
  fill(0, 0, 255);
  rect(100, 200, 200, 50); 
  
  // Car roof
  fill(0, 0, 255);
  rect(125, 170, 150, 30); 
  
  // Windows
  fill(255); 
  rect(140, 180, 40, 20); 
  rect(220, 180, 40, 20); 
  
  // Wheels
  fill(0);
  circle(120, 250, 50, 40);  
  circle(280, 250, 50, 40);  
}
